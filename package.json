    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^11.0.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^9.0.10"
  }
}
